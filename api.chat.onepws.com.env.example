# Vercel project: api
# Domain: api.chat.onepws.com
# Root Directory: apps/api
#
# Paste these variables into:
# Vercel Project > api > Settings > Environment Variables
#
# Do not commit real secret values. Replace every CHANGE_ME value before production.

NODE_ENV=production
PORT=5000
APP_NAME=OnePWS_AI_CHATBOT
APP_URL=https://api.chat.onepws.com
WIDGET_URL=https://chat.onepws.com
ADMIN_URL=https://admin.chat.onepws.com
ONEPWS_DOMAIN=https://onepws.com

# Security secrets
# Generate each value with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_32_BYTE_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_32_BYTE_REFRESH_SECRET
SESSION_SECRET=CHANGE_ME_GENERATE_32_BYTE_SESSION_SECRET
ENCRYPTION_SECRET=CHANGE_ME_GENERATE_32_BYTE_ENCRYPTION_SECRET

# Database
# MongoDB Atlas example:
# mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/onepws-chatbot?retryWrites=true&w=majority
MONGODB_URI=CHANGE_ME_MONGODB_ATLAS_URI

# Redis / queue
# Required if you deploy the worker and want queued email/sheets processing.
# The API can still run without Redis because queue code falls back to inline processing.
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# OpenAI / AI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_SUMMARY_MODEL=gpt-5.4-mini
OPENAI_EXTRACTION_MODEL=gpt-5.4-mini

# Optional self-hosted Ollama fallback
OLLAMA_GENERATE_URL=
OLLAMA_MODEL=llama3.2

# Google Sheets
# For GOOGLE_PRIVATE_KEY in Vercel, paste the private key with literal \n newlines.
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_MASTER_ID=
GOOGLE_SHEETS_ONEPWS_ID=

# Gmail OAuth
GMAIL_SENDER_NAME=OnePWS Lead Bot
GMAIL_FROM_EMAIL=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Lead routing emails
MARKETING_CC_EMAIL=marketing@onepws.com
FALLBACK_LEAD_EMAIL=marketing@onepws.com
DEPT_CONTROL_ROOM_EMAIL=control-room@onepws.com
DEPT_CONSOLES_EMAIL=consoles@onepws.com
DEPT_INTERIORS_EMAIL=interiors@onepws.com
DEPT_FLOORING_EMAIL=flooring@onepws.com
DEPT_MODULAR_OT_EMAIL=modular-ot@onepws.com
DEPT_SUPPORT_EMAIL=support@onepws.com
DEPT_ENTERPRISE_SOLUTIONS_EMAIL=enterprise@onepws.com

# Limits / logging
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=info

# Feature flags
ENABLE_EMAIL=false
ENABLE_GOOGLE_SHEETS=false
ENABLE_LEAD_SCORING=true
ENABLE_CUSTOMER_ACK_EMAIL=false
ENABLE_FILE_UPLOAD=false
ENABLE_RAG=false

# CAPTCHA
CAPTCHA_SECRET=
