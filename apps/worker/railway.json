{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run build:worker",
    "watchPatterns": [
      "/apps/worker/**",
      "/packages/config/**",
      "/packages/core/**",
      "/packages/types/**",
      "/packages/utils/**",
      "/package.json",
      "/package-lock.json",
      "/railpack.json",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "npm run start:worker",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
